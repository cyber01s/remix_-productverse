rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() {
      // Must be signed in. We assume email verification is required for standard users.
      // If anonymous auth is required later, we can adjust here.
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS ---
    
    function isValidProduct(data) {
      // Products are only created by admin, but we include blueprint for completeness
      return data.keys().hasAll(['name', 'slug', 'price']) && 
             data.name is string && data.name.size() <= 200 &&
             data.slug is string && data.slug.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.get('category', '') is string && data.get('category', '').size() <= 50 &&
             data.get('rating', 0) is number &&
             data.get('reviewCount', 0) is number;
    }

    function isValidReview(data) {
       // Shared shape validation: types, boundaries, structure
       // It strictly ensures there are no ghost fields.
       return data.keys().hasAll(['productId', 'userId', 'rating', 'body', 'status', 'createdAt']) &&
              data.keys().size() <= 6 &&
              data.productId is string && data.productId.size() <= 128 &&
              data.userId is string && data.userId == request.auth.uid &&
              data.rating is number && data.rating >= 1 && data.rating <= 5 &&
              data.body is string && data.body.size() <= 5000 &&
              data.status is string && data.status in ['pending', 'approved', 'rejected'] &&
              data.createdAt is timestamp;
    }

    function isValidClick(data) {
      return data.keys().hasAll(['productId', 'source', 'timestamp']) &&
             data.keys().size() <= 4 &&
             data.productId is string && data.productId.size() <= 128 &&
             data.get('userId', '') is string && data.get('userId', '').size() <= 128 &&
             data.source is string && data.source.size() <= 200 &&
             data.timestamp is timestamp;
    }

    // --- COLLECTIONS ---

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
    }

    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId) && (existing().status == 'approved' || (isSignedIn() && existing().userId == request.auth.uid));
      allow list: if existing().status == 'approved' || (isSignedIn() && existing().userId == request.auth.uid);

      allow create: if isSignedIn() 
                    && isValidId(reviewId) 
                    && isValidReview(incoming()) 
                    && incoming().createdAt == request.time
                    && incoming().status == 'pending';

      allow update: if isSignedIn() 
                    && isValidId(reviewId)
                    && isValidReview(incoming()) // Required by CRITICAL SYNTAX MANDATE
                    && existing().userId == request.auth.uid
                    && existing().status == 'pending' // terminal state guard
                    && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'body', 'status', 'updatedAt'])
                    && incoming().status == existing().status // user cannot manipulate their status
                    && incoming().productId == existing().productId // immortal
                    && incoming().userId == existing().userId // immortal
                    && incoming().createdAt == existing().createdAt; // immortal

      allow delete: if isSignedIn() && isValidId(reviewId) && existing().userId == request.auth.uid;
    }

    match /clicks/{clickId} {
      // No email verify required for clicks, it could be a guest
      allow create: if request.auth == null || request.auth != null // Any guest or user
                    && isValidId(clickId) 
                    && isValidClick(incoming())
                    && incoming().timestamp == request.time
                    && exists(/databases/$(database)/documents/products/$(incoming().productId));
      allow read, update, delete: if false; 
    }
  }
}
