rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES (Phase 3) ---
    function isSignedIn() {
      // Must be signed in AND have verified email 
      // (Unless email verification is physically not required for app constraints. Since 
      // the blueprint insists on verify checking, we check it where possible. But some users
      // may not have email or it could be anonymous. Let's stick strictly to what the "Fortress Rules" say unless overridden).
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Helper: is owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS (Phase 2 & 4.2) ---
    
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'slug', 'price']) && 
             data.name is string && data.name.size() <= 200 &&
             data.slug is string && data.slug.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.get('category', '') is string && data.get('category', '').size() <= 50 &&
             data.get('rating', 0) is number &&
             data.get('reviewCount', 0) is number;
    }

    function isValidReview(data) {
       // Fields: productId, userId, rating, body, status, createdAt
       // Note on exact keys for creation, diff check for update.
       return data.keys().hasAll(['productId', 'userId', 'rating', 'body', 'status', 'createdAt']) &&
              data.keys().size() <= 6 &&
              data.productId is string && data.productId.size() <= 128 &&
              data.userId is string && data.userId == request.auth.uid &&
              data.rating is number && data.rating >= 1 && data.rating <= 5 &&
              data.body is string && data.body.size() <= 5000 &&
              data.status is string && data.status in ['pending', 'approved', 'rejected'] &&
              data.createdAt == request.time;
    }

    function isValidClick(data) {
      return data.keys().hasAll(['productId', 'source', 'timestamp']) &&
             data.keys().size() <= 4 && // userId is optional
             data.productId is string && data.productId.size() <= 128 &&
             data.get('userId', '') is string && data.get('userId', '').size() <= 128 &&
             data.source is string && data.source.size() <= 200 &&
             data.timestamp == request.time;
    }

    // --- COLLECTIONS ---

    match /products/{productId} {
      allow get: if isValidId(productId);
      
      // Clients must list safely if we had condition. Since all products are public to read, we allow list.
      // But query should only be for visible products if there is a visibility check. 
      // The rules don't enforce visibility right now, but let's at least enforce the list.
      allow list: if true; 

      // No writes via client (Admin-only, implemented implicitly by missing write rules)
    }

    match /reviews/{reviewId} {
      // Relational Gate: read is allowed if it is approved OR if the user is the owner
      allow get: if isValidId(reviewId) && (existing().status == 'approved' || (isSignedIn() && existing().userId == request.auth.uid));
      allow list: if existing().status == 'approved' || (isSignedIn() && existing().userId == request.auth.uid);

      allow create: if isSignedIn() 
                    && isValidId(reviewId) 
                    && isValidReview(incoming()) 
                    && incoming().status == 'pending'
                    // ensure product actually exists
                    && exists(/databases/$(database)/documents/products/$(incoming().productId));

      allow update: if isSignedIn() 
                    && isValidId(reviewId) 
                    && existing().userId == request.auth.uid
                    && existing().status == 'pending' // terminal state guard
                    && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'body', 'status'])
                    // Redefining valid aspects for partial payload
                    && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
                    && incoming().body is string && incoming().body.size() <= 5000
                    && incoming().status in ['pending', 'approved', 'rejected']
                    && incoming().status == existing().status // cannot promote self to approved
                    // Check immutables manually since isValidReview isn't perfectly built for diff
                    && incoming().productId == existing().productId
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;

      allow delete: if isSignedIn() && isValidId(reviewId) && existing().userId == request.auth.uid;
    }

    match /clicks/{clickId} {
      allow create: if isValidId(clickId) 
                    && isValidClick(incoming())
                    && exists(/databases/$(database)/documents/products/$(incoming().productId));
      // Analytics collection: users cannot read, edit, or delete existing clicks.
      allow read, update, delete: if false; 
    }
  }
}
